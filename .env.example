# App settings
APP_ENV=local
APP_PORT=3000
APP_TITLE=FSD App API

# Frontend settings (no trailing slash)
FRONTEND_URL=https://example.com

# Refresh JWT cookie settings
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/
REFRESH_COOKIE_SECURE=true

# MongoDB settings (overridden by .env.docker inside containers)
MONGODB_URI=mongodb://127.0.0.1:27017/fsd_app

# JWT Config — generate fresh secrets with: openssl rand -hex 32
JWT_SESSION_SECRET=<GENERATE_ME>
JWT_SESSION_TTL=3600
JWT_REFRESH_SECRET=<GENERATE_ME>
JWT_REFRESH_TTL=604800

# Airtable OAuth Config — see DEPLOYMENT.md section "Airtable OAuth integration"
AIRTABLE_CLIENT_ID=<FROM_AIRTABLE_DEVELOPER_PORTAL>
AIRTABLE_CLIENT_SECRET=<FROM_AIRTABLE_DEVELOPER_PORTAL>
AIRTABLE_OAUTH_REDIRECT_URI=https://example.com/api/oauth/airtable/callback
AIRTABLE_OAUTH_SCOPES=schema.bases:read data.records:read user.email:read
